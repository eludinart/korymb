{
  "name": "korymb",
  "private": true,
  "version": "3.0.3",
  "scripts": {
    "verify:api": "node tools/verify-korymb-health.mjs",
    "smoke:deploy": "node tools/smoke-post-deploy.mjs",
    "dev": "node tools/verify-korymb-health.mjs && npm --prefix admin run dev",
    "build": "npm --prefix admin run build",
    "start": "npm --prefix admin run start",
    "lint": "npm --prefix admin run lint",
    "lint:admin": "npm --prefix admin run lint",
    "build:admin": "npm --prefix admin run build",
    "check:backend": "python -m compileall -q backend",
    "check:backend:tests": "cd backend && python -m pytest tests/ evals/ -q",
    "generate:api-schema": "node tools/generate-api-schema.mjs",
    "check": "npm run build && npm run check:backend && npm run check:backend:tests"
  },
  "dependencies": {},
  "devDependencies": {}
}
