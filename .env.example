# Copier en .env.local et remplir

# URL du backend FastAPI (agents IA)
# Dev :
VITE_AI_BACKEND_URL=http://localhost:8000
# Prod :
# VITE_AI_BACKEND_URL=https://api.eludein.art

# Secret partagé avec le backend (même valeur que AGENT_API_SECRET dans ai-backend/.env)
VITE_AGENT_SECRET=remplacer_par_le_meme_secret
