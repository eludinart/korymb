# Copier vers admin/.env.local (Next.js lit admin/, pas la racine du repo).
# copy admin\.env.local.example admin\.env.local

# URL du backend FastAPI (agents IA), sans suffixe /api.
# Front Next.js unifie : utilise NEXT_PUBLIC_KORYMB_API_URL.
NEXT_PUBLIC_KORYMB_API_URL=http://127.0.0.1:8020
# Optionnel : port de dev Next.js (par defaut 3000).
PORT=3000

# `npm run dev` lance d abord tools/verify-korymb-health.mjs (GET /health doit avoir code_dir + version).
# Frontend seul : PowerShell  $env:KORYMB_SKIP_VERIFY=1 ; npm run dev

# Prod :
# NEXT_PUBLIC_KORYMB_API_URL=https://api-korymb.eludein.art

# Secret partage avec le backend (meme valeur que AGENT_API_SECRET dans backend/.env)
# Dev local uniquement pour les routes proxy Next si KORYMB_AGENT_SECRET absent :
NEXT_PUBLIC_KORYMB_AGENT_SECRET=remplacer_par_le_meme_secret
# Production / obligatoire pour les routes app/api/* :
KORYMB_AGENT_SECRET=remplacer_par_le_meme_secret
