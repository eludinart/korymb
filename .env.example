# Copier en .env ou .env.local et remplir

# URL du backend FastAPI (agents IA), sans suffixe /api (les routes sont /jobs, /run… a la racine du service).
# En dev le front appelle cette URL en direct (CORS * cote backend en development). Preferer 127.0.0.1.
VITE_AI_BACKEND_URL=http://127.0.0.1:8020
# Meme port que uvicorn (backend/restart.ps1 lit VITE_PROXY_TARGET ou UVICORN_PORT).
VITE_PROXY_TARGET=http://127.0.0.1:8020
# Eviter le port 8010 en local sous Windows : plusieurs LISTEN peuvent renvoyer un vieux /health (3.0.0).

# `npm run dev` lance d abord tools/verify-korymb-health.mjs (GET /health doit avoir code_dir + version).
# Frontend seul : PowerShell  $env:KORYMB_SKIP_VERIFY=1 ; npm run dev

# Prod :
# VITE_AI_BACKEND_URL=https://api-korymb.eludein.art

# Secret partage avec le backend (meme valeur que AGENT_API_SECRET dans backend/.env si present)
VITE_AGENT_SECRET=remplacer_par_le_meme_secret
