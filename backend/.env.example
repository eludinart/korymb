ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODELS=claude-sonnet-4-6,claude-3-5-haiku-latest
# Fournisseur actif: anthropic | openrouter
LLM_PROVIDER=anthropic

# OpenRouter — modèles Google/Gemma passent par OpenRouter (suffixe :free = couche gratuite OpenRouter, quotas).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODELS=google/gemma-3-27b-it:free,google/gemma-2-9b-it:free,google/gemma-7b-it:free,google/gemini-2.0-flash-exp:free,openai/gpt-4o-mini,google/gemini-2.5-flash-lite,anthropic/claude-3.5-haiku
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AGENT_API_SECRET=korymb-secret-2026
ENV=production

# Base backend Korymb (par défaut sqlite). Pour MariaDB:
# KORYMB_DB_ENGINE=mariadb
# KORYMB_DB_HOST=127.0.0.1
# KORYMB_DB_PORT=3306
# KORYMB_DB_USER=korymb
# KORYMB_DB_PASSWORD=
# KORYMB_DB_NAME=korymb
KORYMB_DB_ENGINE=sqlite

# Base de données Fleur d'Amours (VPS — hostname interne Coolify)
FLEUR_DB_HOST=juehpsnqkm60d2o6dhs38c5t
FLEUR_DB_PORT=3306
FLEUR_DB_USER=mariadb
FLEUR_DB_PASSWORD=...
FLEUR_DB_NAME=default

# Réseaux sociaux (optionnel)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Agents autonomes — intégration Meta Webhooks (optionnel)
# Générer un token de Page longue durée dans Meta for Developers > Mes Apps > Webhooks
META_PAGE_ACCESS_TOKEN=
# Token de vérification à renseigner dans Meta for Developers > Webhooks (valeur libre)
META_WEBHOOK_VERIFY_TOKEN=korymb-webhook-2026

# Email SMTP (optionnel)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Google Drive (optionnel)
# Token OAuth2 Bearer avec scope Drive (ex. https://www.googleapis.com/auth/drive.file)
# Laisse vide pour utiliser GOOGLE_API_ACCESS_TOKEN.
GOOGLE_DRIVE_ACCESS_TOKEN=
# Dossier cible par défaut (optionnel)
GOOGLE_DRIVE_FOLDER_ID=

# Google OAuth (multi-scope) — optionnel
# Source unique recommandée : un seul token OAuth avec scopes multiples.
GOOGLE_API_ACCESS_TOKEN=
# Renouvellement automatique (optionnel, recommandé)
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optionnel (par défaut https://oauth2.googleapis.com/token)
GOOGLE_OAUTH_TOKEN_ENDPOINT=
# Tokens dédiés par service (optionnels) — prioritaires s'ils sont définis.
GOOGLE_GMAIL_ACCESS_TOKEN=
GOOGLE_SHEETS_ACCESS_TOKEN=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_DOCS_ACCESS_TOKEN=
