# Copier en backend/.env.local (gitignore) pour le dev local vers MariaDB VPS.
# Le port 3306 n'est en general pas expose sur Internet : utiliser le tunnel SSH
#   .\scripts\mariadb-vps-tunnel.ps1
# puis demarrer le backend.

KORYMB_DB_ENGINE=mariadb
KORYMB_DB_HOST=127.0.0.1
KORYMB_DB_PORT=3307

# Identifiants : laisser dans backend/.env (KORYMB_DB_USER, KORYMB_DB_PASSWORD, KORYMB_DB_NAME)
# ou surcharger ici si besoin.
