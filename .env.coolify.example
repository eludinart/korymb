# Frontend (Next.js unified app) - runtime
PORT=3000
NODE_ENV=production

# Public values exposed to browser bundle
NEXT_PUBLIC_KORYMB_API_URL=https://api-korymb.example.com
NEXT_PUBLIC_KORYMB_AGENT_SECRET=replace_with_shared_agent_secret

# Server-side values used by Next API routes
KORYMB_API_URL=https://api-korymb.example.com
KORYMB_AGENT_SECRET=replace_with_shared_agent_secret
